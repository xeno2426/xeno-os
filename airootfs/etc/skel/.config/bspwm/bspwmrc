#!/bin/sh

# ─── Monitors & Workspaces ────────────────────────────────────────────────────
bspc monitor -d I II III IV V VI VII VIII IX X

# ─── Window Behaviour ─────────────────────────────────────────────────────────
bspc config border_width          2
bspc config window_gap            12
bspc config split_ratio           0.52
bspc config borderless_monocle    true
bspc config gapless_monocle       false
bspc config focus_follows_pointer true
bspc config pointer_follows_focus false
bspc config click_to_focus        button1

# ─── Catppuccin Mocha Border Colors ───────────────────────────────────────────
bspc config normal_border_color   "#45475a"
bspc config active_border_color   "#585b70"
bspc config focused_border_color  "#89b4fa"
bspc config presel_feedback_color "#313244"

# ─── Padding (leave room for polybar at top) ──────────────────────────────────
bspc config top_padding    40
bspc config bottom_padding 8
bspc config left_padding   0
bspc config right_padding  0

# ─── Rules ────────────────────────────────────────────────────────────────────
bspc rule -a Plank         layer=above manage=off border=off focus=off
bspc rule -a Polybar       manage=off border=off
bspc rule -a Conky         manage=off border=off layer=below sticky=on
bspc rule -a Rofi          manage=off border=off
bspc rule -a kitty         border=on
bspc rule -a Thunar        state=tiled
bspc rule -a \*:float      state=floating

# ─── Autostart ────────────────────────────────────────────────────────────────

# Input & keybindings
sxhkd &

# Compositor (blur + shadows + rounded corners)
picom --config "$HOME/.config/picom/picom.conf" &

# Wallpaper
nitrogen --restore &

# Top bar (macOS-style)
"$HOME/.config/polybar/launch.sh" &

# Dock (macOS-style bottom dock)
plank &

# Notification daemon
dunst &
