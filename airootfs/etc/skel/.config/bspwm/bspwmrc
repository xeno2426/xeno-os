#!/bin/sh

# ─── Monitors & Workspaces ────────────────────────────────────────────────────
# Distribute 10 workspaces across all connected monitors
MONITORS=$(xrandr --query | grep ' connected' | cut -d' ' -f1)
MONITOR_COUNT=$(echo "$MONITORS" | wc -l)

if [ "$MONITOR_COUNT" -ge 2 ]; then
    i=1
    for mon in $MONITORS; do
        case $i in
            1) bspc monitor "$mon" -d I II III IV V ;;
            2) bspc monitor "$mon" -d VI VII VIII IX X ;;
            *) bspc monitor "$mon" -d X ;;
        esac
        i=$((i+1))
    done
else
    bspc monitor -d I II III IV V VI VII VIII IX X
fi

# ─── Window Behaviour ─────────────────────────────────────────────────────────
bspc config border_width           2
bspc config window_gap             12
bspc config split_ratio            0.52
bspc config borderless_monocle     true
bspc config gapless_monocle        false
bspc config focus_follows_pointer  true
bspc config pointer_follows_focus  false
bspc config click_to_focus         button1

# ─── Border Colours (Catppuccin Mocha) ───────────────────────────────────────
bspc config normal_border_color    "#45475a"
bspc config active_border_color    "#585b70"
bspc config focused_border_color   "#89b4fa"
bspc config presel_feedback_color  "#313244"

# ─── Padding (room for polybar top bar) ──────────────────────────────────────
bspc config top_padding    40
bspc config bottom_padding 8
bspc config left_padding   0
bspc config right_padding  0

# ─── Window Rules ─────────────────────────────────────────────────────────────
bspc rule -a Plank         layer=above manage=off border=off focus=off sticky=on
bspc rule -a Polybar       manage=off border=off
bspc rule -a Conky         manage=off border=off layer=below sticky=on
bspc rule -a Rofi          manage=off border=off
bspc rule -a Dunst         manage=off border=off
bspc rule -a kitty         border=on state=tiled
bspc rule -a Brave-browser state=tiled
bspc rule -a Thunar        state=tiled
bspc rule -a "\*:float"    state=floating

# ─── Autostart ────────────────────────────────────────────────────────────────

# Fallback solid background colour while wallpaper loads
xsetroot -solid "#1e1e2e" &

# Keybind daemon
sxhkd &

# Compositor
picom --config "$HOME/.config/picom/picom.conf" --daemon

# Wallpaper — restore saved or set fallback
if command -v nitrogen &>/dev/null; then
    nitrogen --restore 2>/dev/null || xsetroot -solid "#1e1e2e"
fi

# macOS-style top bar
"$HOME/.config/polybar/launch.sh" &

# macOS-style bottom dock
plank &

# Notification daemon
dunst &

# Lock screen on idle / lid close
xss-lock --transfer-sleep-lock -- xeno-lock &

echo "bspwm: environment ready" | systemd-cat -t bspwm 2>/dev/null || true
