#!/usr/bin/env bash
# xeno-lock — Lock screen with betterlockscreen, fallback to i3lock
if command -v betterlockscreen &>/dev/null; then
    betterlockscreen --lock dimblur
elif command -v i3lock &>/dev/null; then
    i3lock -c 1e1e2e
else
    xscreensaver-command -lock 2>/dev/null || \
    notify-send "Lock" "No lock screen tool found." -i dialog-warning
fi
