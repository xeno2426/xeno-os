#!/usr/bin/env python3
"""xeno-wallpaper — Generate Catppuccin Mocha gradient wallpapers."""
import os, math, sys
from pathlib import Path

OUT_DIR = Path.home() / ".local/share/backgrounds/xeno-os"
OUT_DIR.mkdir(parents=True, exist_ok=True)

try:
    from PIL import Image, ImageDraw
except ImportError:
    print("[xeno-wallpaper] python-pillow not found.")
    print("  Install with: sudo pacman -S python-pillow")
    sys.exit(1)

W, H = 2560, 1440

def hex_to_rgb(h):
    h = h.lstrip('#')
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))

# ─── Wallpaper 1: Deep Space Gradient ────────────────────────────────────────
def wp_deep_space():
    img  = Image.new("RGBA", (W, H))
    d    = ImageDraw.Draw(img)
    top    = hex_to_rgb("#11111b")
    bottom = hex_to_rgb("#1e1e2e")
    accent = hex_to_rgb("#89b4fa")

    for y in range(H):
        t = y / H
        r = int(top[0] + (bottom[0] - top[0]) * t)
        g = int(top[1] + (bottom[1] - top[1]) * t)
        b = int(top[2] + (bottom[2] - top[2]) * t)
        d.line([(0, y), (W, y)], fill=(r, g, b, 255))

    # Radial glow composite
    glow = Image.new("RGBA", (W, H), (0, 0, 0, 0))
    gd   = ImageDraw.Draw(glow)
    cx, cy = W // 2, H // 2
    for radius in range(300, 0, -2):
        a = int(8 * (1 - radius / 300))
        gd.ellipse([cx-radius, cy-radius, cx+radius, cy+radius],
                   fill=(accent[0], accent[1], accent[2], a))
    return Image.alpha_composite(img, glow).convert("RGB")

# ─── Wallpaper 2: Mocha Grid ──────────────────────────────────────────────────
def wp_grid():
    img  = Image.new("RGB", (W, H), hex_to_rgb("#1e1e2e"))
    d    = ImageDraw.Draw(img)
    step = 80
    for x in range(0, W, step):
        d.line([(x, 0), (x, H)], fill=hex_to_rgb("#2a2a3d"), width=1)
    for y in range(0, H, step):
        d.line([(0, y), (W, y)], fill=hex_to_rgb("#2a2a3d"), width=1)

    cx, cy = W // 2, H // 2
    blue  = hex_to_rgb("#89b4fa")
    mauve = hex_to_rgb("#cba6f7")
    for ix in range(-8, 9):
        for iy in range(-5, 6):
            dist = math.sqrt(ix**2 + iy**2)
            if dist > 9:
                continue
            px = cx + ix * step
            py = cy + iy * step
            alpha = max(0.0, 1 - dist / 9)
            color = blue if (ix + iy) % 2 == 0 else mauve
            r2 = max(1, int(4 * alpha))
            d.ellipse([px-r2, py-r2, px+r2, py+r2], fill=color)
    return img

# ─── Wallpaper 3: Diagonal Waves — fixed ─────────────────────────────────────
def wp_waves():
    img = Image.new("RGB", (W, H))
    d   = ImageDraw.Draw(img)
    colors = [
        hex_to_rgb("#11111b"),
        hex_to_rgb("#181825"),
        hex_to_rgb("#1e1e2e"),
        hex_to_rgb("#313244"),
    ]
    num_bands = len(colors) - 1
    band_h    = H / num_bands

    for y in range(H):
        # Wave offset shifts which color band is visible at this x-scanline
        wave_offset = int(40 * math.sin(y / 180))
        band_idx = min(int(y / band_h), num_bands - 1)
        t = (y - band_idx * band_h) / band_h
        c1 = colors[band_idx]
        c2 = colors[min(band_idx + 1, num_bands)]
        r = int(c1[0] + (c2[0] - c1[0]) * t)
        g = int(c1[1] + (c2[1] - c1[1]) * t)
        b = int(c1[2] + (c2[2] - c1[2]) * t)
        d.line([(0, y), (W, y)], fill=(r, g, b))

    # Overlay subtle diagonal shimmer lines
    shimmer = hex_to_rgb("#313244")
    for x in range(-H, W, 120):
        d.line([(x, 0), (x + H, H)], fill=shimmer, width=1)

    return img

wallpapers = [
    ("xeno-deep-space.png", wp_deep_space),
    ("xeno-grid.png",       wp_grid),
    ("xeno-waves.png",      wp_waves),
]

for name, fn in wallpapers:
    path = OUT_DIR / name
    print(f"  Generating {name}...", end=" ", flush=True)
    try:
        img = fn()
        img.save(str(path), "PNG", optimize=True)
        print("done")
    except Exception as e:
        print(f"FAILED ({e})")

print(f"\nWallpapers saved to {OUT_DIR}")
